<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fitness.modules.equipment.mapper.EquipmentRepairMapper">

    <!-- 报修VO结果映射 -->
    <resultMap id="RepairVOResultMap" type="com.fitness.modules.equipment.model.vo.RepairVO">
        <id column="id" property="id"/>
        <result column="equipment_id" property="equipmentId"/>
        <result column="equipment_name" property="equipmentName"/>
        <result column="user_id" property="userId"/>
        <result column="user_name" property="userName"/>
        <result column="description" property="description"/>
        <result column="image_url" property="imageUrl"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="handle_time" property="handleTime"/>
    </resultMap>

    <!-- 查询器材的报修记录 -->
    <select id="selectRepairList" resultMap="RepairVOResultMap">
        SELECT
            r.id,
            r.equipment_id,
            e.equipment_name,
            r.user_id,
            u.username AS user_name,
            r.description,
            r.image_url,
            r.status,
            r.create_time,
            r.handle_time
        FROM fitness_equipment_repair r
        LEFT JOIN fitness_equipment e ON r.equipment_id = e.id
        LEFT JOIN sys_user u ON r.user_id = u.id
        WHERE r.equipment_id = #{equipmentId}
        ORDER BY r.create_time DESC
    </select>

    <!-- 我的报修记录VO结果映射 -->
    <resultMap id="MyRepairVOResultMap" type="com.fitness.modules.equipment.model.vo.MyRepairVO">
        <id column="id" property="id"/>
        <result column="equipment_id" property="equipmentId"/>
        <result column="equipment_name" property="equipmentName"/>
        <result column="description" property="description"/>
        <result column="image_url" property="imageUrl"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="handle_time" property="handleTime"/>
    </resultMap>

    <!-- 查询用户的报修记录 -->
    <select id="selectMyRepairs" resultMap="MyRepairVOResultMap">
        SELECT
            r.id,
            r.equipment_id,
            e.equipment_name,
            r.description,
            r.image_url,
            r.status,
            r.create_time,
            r.handle_time
        FROM fitness_equipment_repair r
        LEFT JOIN fitness_equipment e ON r.equipment_id = e.id
        WHERE r.user_id = #{userId} AND r.deleted = false
        ORDER BY r.create_time DESC
    </select>

    <!-- 查询所有报修记录 -->
    <select id="selectAllRepairs" resultMap="RepairVOResultMap">
        SELECT
            r.id,
            r.equipment_id,
            e.equipment_name,
            r.user_id,
            u.username AS user_name,
            r.description,
            r.image_url,
            r.status,
            r.create_time,
            r.handle_time
        FROM fitness_equipment_repair r
        LEFT JOIN fitness_equipment e ON r.equipment_id = e.id
        LEFT JOIN sys_user u ON r.user_id = u.id
        ORDER BY r.create_time DESC
    </select>

</mapper>
