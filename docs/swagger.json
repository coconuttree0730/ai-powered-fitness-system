    "/api/v1/admin/users": {
      "get": {
        "summary": "分页查询用户列表",
        "description": "分页查询用户列表",
        "tags": ["用户模块"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"name": "pageNum", "in": "query", "type": "integer", "default": 1, "description": "页码"},
          {"name": "pageSize", "in": "query", "type": "integer", "default": 10, "description": "每页数量"},
          {"name": "username", "in": "query", "type": "string", "description": "用户名"},
          {"name": "phone", "in": "query", "type": "string", "description": "手机号"},
          {"name": "status", "in": "query", "type": "integer", "description": "状态"}
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "schema": {
              "$ref": "#/definitions/ResultPageUserVO"
            }
          }
        }
      },
      "post": {
        "summary": "创建用户",
        "description": "管理员创建新用户",
        "tags": ["用户模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UserDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "创建成功",
            "schema": {
              "$ref": "#/definitions/ResultLong"
            }
          }
        }
      }
    },
    "/api/v1/admin/users/{id}": {
      "put": {
        "summary": "更新用户",
        "description": "更新用户信息",
        "tags": ["用户模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "type": "integer", "description": "用户ID"},
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UserUpdateDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "更新成功",
            "schema": {
              "$ref": "#/definitions/Result"
            }
          }
        }
      },
      "delete": {
        "summary": "删除用户",
        "description": "删除用户",
        "tags": ["用户模块"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "type": "integer", "description": "用户ID"}
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "schema": {
              "$ref": "#/definitions/Result"
            }
          }
        }
      }
    },
    "/api/v1/profile": {
      "get": {
        "summary": "获取健身档案",
        "description": "获取当前用户的健身档案",
        "tags": ["用户模块"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
            "description": "获取成功",
            "schema": {
              "$ref": "#/definitions/ResultUserFitnessProfileVO"
            }
          }
        }
      },
      "put": {
        "summary": "更新健身档案",
        "description": "创建或更新健身档案",
        "tags": ["用户模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UserFitnessProfileDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "更新成功",
            "schema": {
              "$ref": "#/definitions/ResultUserFitnessProfileVO"
            }
          }
        }
      }
    },
