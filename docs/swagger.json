    "/api/v1/users/email": {
      "put": {
        "summary": "更新邮箱",
        "description": "更新当前用户邮箱",
        "tags": ["用户模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UpdateEmailDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "更新成功",
