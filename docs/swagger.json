    "/api/v1/plans/my": {
      "get": {
        "summary": "获取我的计划列表",
        "description": "获取当前用户的健身计划列表",
        "tags": ["健身计划模块"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
