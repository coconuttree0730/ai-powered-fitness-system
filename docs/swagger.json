              "$ref": "#/definitions/ResultListCoachVO"
            }
          }
        }
      }
    },
    "/api/v1/coaches/home": {
      "get": {
        "summary": "获取首页教练列表",
        "description": "获取首页展示的教练列表",
        "tags": ["教练模块"],
        "produces": ["application/json"],
        "parameters": [
          {"name": "limit", "in": "query", "type": "integer", "default": 4, "description": "限制数量"}
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "schema": {
              "$ref": "#/definitions/ResultListHomePageCoachVO"
            }
          }
        }
      }
    },
