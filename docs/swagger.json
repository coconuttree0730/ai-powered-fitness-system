  "definitions": {
    "Result": {
      "type": "object",
      "properties": {
        "code": {"type": "integer", "description": "状态码"},
        "message": {"type": "string", "description": "消息"},
        "data": {"type": "object", "description": "数据"}
      },
      "example": {"code": 200, "message": "success", "data": {}}
    },
    "ResultUserVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"$ref": "#/definitions/UserVO"}
      }
    },
    "ResultTokenInfo": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {
          "type": "object",
          "properties": {
            "token": {"type": "string", "description": "访问令牌"},
            "refreshToken": {"type": "string", "description": "刷新令牌"},
            "expiresIn": {"type": "integer", "description": "过期时间（秒）"}
          }
        }
      }
    },
    "ResultSliderVerifyTokenVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"$ref": "#/definitions/SliderVerifyTokenVO"}
      }
    },
    "ResultSliderVerifyResultVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"$ref": "#/definitions/SliderVerifyResultVO"}
      }
    },
    "ResultSmsCodeResponse": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {
          "type": "object",
          "properties": {
            "sent": {"type": "boolean", "description": "是否发送成功"},
            "message": {"type": "string", "description": "提示信息"},
            "remainingSeconds": {"type": "integer", "description": "剩余秒数"},
            "remainingDailyCount": {"type": "integer", "description": "剩余每日发送次数"}
          }
        }
      }
    },
    "ResultLong": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"type": "integer", "format": "int64", "description": "ID值"}
      }
    },
    "ResultPageUserVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"$ref": "#/definitions/PageUserVO"}
      }
    },
    "ResultPageCourseVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"$ref": "#/definitions/PageCourseVO"}
      }
    },
    "ResultListCoachVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"type": "array", "items": {"$ref": "#/definitions/CoachVO"}}
      }
    },
    "ResultListHomePageCoachVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"type": "array", "items": {"$ref": "#/definitions/HomePageCoachVO"}}
      }
    },
    "ResultListCourseCardVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"type": "array", "items": {"$ref": "#/definitions/CourseCardVO"}}
      }
    },
    "ResultListPlanVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"type": "array", "items": {"$ref": "#/definitions/PlanVO"}}
      }
    },
    "ResultPlanVO": {
      "type": "object",
      "properties": {
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "data": {"$ref": "#/definitions/PlanVO"}
