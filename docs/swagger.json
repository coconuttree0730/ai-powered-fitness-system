    "/api/v1/users/avatar": {
      "post": {
        "summary": "上传头像",
        "description": "上传用户头像",
        "tags": ["用户模块"],
        "consumes": ["multipart/form-data"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "in": "formData",
            "name": "file",
            "type": "file",
            "required": true,
            "description": "头像图片文件"
          }
