{
  "swagger": "2.0",
  "info": {
    "title": "AI健身系统API",
    "description": "AI健身系统后端API接口文档",
    "version": "1.0.0",
    "contact": {
      "name": "AI健身系统开发团队",
      "email": "contact@fitness-system.com"
    }
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": ["http"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "请在请求头中添加：Bearer {token}"
    }
  },
  "paths": {
    "/api/v1/auth/register": {
      "post": {
        "summary": "用户注册",
        "description": "用户注册新账号",
        "tags": ["认证模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UserDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "注册成功",
            "schema": {
              "$ref": "#/definitions/ResultUserVO"
            }
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "summary": "用户登录",
        "description": "用户登录获取Token",
        "tags": ["认证模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LoginDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "登录成功",
            "schema": {
              "$ref": "#/definitions/ResultTokenInfo"
            }
          }
        }
      }
    },
    "/api/v1/auth/slider-verify/token": {
      "get": {
        "summary": "获取滑块验证令牌",
        "description": "获取滑块验证所需的令牌",
        "tags": ["认证模块"],
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "获取成功",
            "schema": {
              "$ref": "#/definitions/ResultSliderVerifyTokenVO"
            }
          }
        }
      }
    },
    "/api/v1/auth/slider-verify/verify": {
      "post": {
        "summary": "验证滑块结果",
        "description": "验证滑块验证结果",
        "tags": ["认证模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SliderVerifyDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "验证成功",
            "schema": {
              "$ref": "#/definitions/ResultSliderVerifyResultVO"
            }
          }
        }
      }
    },
    "/api/v1/auth/sms-code": {
      "post": {
        "summary": "发送短信验证码",
        "description": "发送短信验证码，需要先完成滑块验证",
        "tags": ["认证模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SmsCodeDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "发送成功",
            "schema": {
              "$ref": "#/definitions/ResultSmsCodeResponse"
            }
          }
        }
      }
    },
    "/api/v1/auth/login/sms": {
      "post": {
        "summary": "短信验证码登录",
        "description": "使用短信验证码登录，未注册用户自动创建",
        "tags": ["认证模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SmsCodeLoginDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "登录成功",
            "schema": {
              "$ref": "#/definitions/ResultTokenInfo"
            }
          }
        }
      }
    },
    "/api/v1/users/me": {
      "get": {
        "summary": "获取当前用户信息",
        "description": "获取当前登录用户的详细信息",
        "tags": ["用户模块"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
            "description": "获取成功",
            "schema": {
              "$ref": "#/definitions/ResultUserVO"
            }
          }
        }
      }
    },
    "/api/v1/users/password": {
      "put": {
        "summary": "修改密码",
        "description": "修改当前用户密码",
        "tags": ["用户模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "oldPassword": {"type": "string", "description": "旧密码"},
                "newPassword": {"type": "string", "description": "新密码"}
              },
              "required": ["oldPassword", "newPassword"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "修改成功",
            "schema": {
              "$ref": "#/definitions/Result"
            }
          }
        }
      }
    },
    "/api/v1/users/username": {
      "put": {
        "summary": "更新用户名",
        "description": "更新当前用户用户名",
        "tags": ["用户模块"],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UpdateUsernameDTO"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "更新成功",
            "schema": {
              "$ref": "#/definitions/ResultUserVO"
            }
          }
        }
      }
    },
    "/api/v1/users/phone": {
      "put": {
        "summary": "更新手机号",
        "description": "更新当前用户手机号",
        "tags": ["用户模块"],
        "consumes": ["application/json"],
