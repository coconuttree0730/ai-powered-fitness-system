      "get": {
        "summary": "获取教练列表",
        "description": "获取所有教练列表",
        "tags": ["教练模块"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
            "description": "获取成功",
