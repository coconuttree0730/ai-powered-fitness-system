          {"name": "category", "in": "query", "type": "string", "description": "课程分类"},
          {"name": "keyword", "in": "query", "type": "string", "description": "关键词"},
          {"name": "pageNum", "in": "query", "type": "integer", "default": 1, "description": "页码"},
          {"name": "pageSize", "in": "query", "type": "integer", "default": 10, "description": "每页数量"}
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "schema": {
              "$ref": "#/definitions/ResultPageCourseVO"
