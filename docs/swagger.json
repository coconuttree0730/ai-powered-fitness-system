      "get": {
        "summary": "获取计划详情",
        "description": "获取健身计划详细信息",
        "tags": ["健身计划模块"],
        "produces": ["application/json"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"name": "planId", "in": "path", "required": true, "type": "integer", "description": "计划ID"}
