<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fitness.modules.equipment.mapper.EquipmentRepairMapper">

    <!-- 报修VO结果映射 -->
    <resultMap id="RepairVOResultMap" type="com.fitness.modules.equipment.model.vo.RepairVO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="user_name" property="userName"/>
        <result column="description" property="description"/>
        <result column="image_urls" property="imageUrls" typeHandler="com.fitness.modules.equipment.handler.ImageUrlsTypeHandler"/>
        <result column="status" property="status"/>
        <result column="handle_remark" property="handleRemark"/>
        <result column="create_time" property="createTime"/>
        <result column="handle_time" property="handleTime"/>
    </resultMap>

    <!-- 查询器材的报修记录 -->
    <select id="selectRepairList" resultMap="RepairVOResultMap">
        SELECT
            r.id,
            r.user_id,
            u.username AS user_name,
            r.description,
            r.image_urls,
            r.status,
            r.handle_remark,
            r.create_time,
            r.handle_time
        FROM fitness_equipment_repair r
        LEFT JOIN sys_user u ON r.user_id = u.id
        WHERE r.deleted = false
        ORDER BY r.create_time DESC
    </select>

    <!-- 我的报修记录VO结果映射 -->
    <resultMap id="MyRepairVOResultMap" type="com.fitness.modules.equipment.model.vo.MyRepairVO">
        <id column="id" property="id"/>
        <result column="description" property="description"/>
        <result column="image_urls" property="imageUrls" typeHandler="com.fitness.modules.equipment.handler.ImageUrlsTypeHandler"/>
        <result column="status" property="status"/>
        <result column="handle_remark" property="handleRemark"/>
        <result column="create_time" property="createTime"/>
        <result column="handle_time" property="handleTime"/>
    </resultMap>

    <!-- 查询用户的报修记录 -->
    <select id="selectMyRepairs" resultMap="MyRepairVOResultMap">
        SELECT
            r.id,
            r.description,
            r.image_urls,
            r.status,
            r.handle_remark,
            r.create_time,
            r.handle_time
        FROM fitness_equipment_repair r
        WHERE r.user_id = #{userId}
          AND r.deleted = false
        ORDER BY r.create_time DESC
    </select>

    <!-- 查询所有报修记录 -->
    <select id="selectAllRepairs" resultMap="RepairVOResultMap">
        SELECT
            r.id,
            r.user_id,
            u.username AS user_name,
            r.description,
            r.image_urls,
            r.status,
            r.handle_remark,
            r.create_time,
            r.handle_time
        FROM fitness_equipment_repair r
        LEFT JOIN sys_user u ON r.user_id = u.id
        WHERE r.deleted = false
        ORDER BY r.create_time DESC
    </select>

    <!-- 根据ID查询报修详情 -->
    <select id="selectRepairById" resultMap="RepairVOResultMap">
        SELECT
            r.id,
            r.user_id,
            u.username AS user_name,
            r.description,
            r.image_urls,
            r.status,
            r.handle_remark,
            r.create_time,
            r.handle_time
        FROM fitness_equipment_repair r
        LEFT JOIN sys_user u ON r.user_id = u.id
        WHERE r.id = #{repairId}
          AND r.deleted = false
    </select>

</mapper>
